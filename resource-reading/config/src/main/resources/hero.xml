<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:people="http://gentryhuang.site/schema/people"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd
       http://gentryhuang.site/schema/people
       http://gentryhuang.site/schema/people/hero.xsd">

    <!--
     1 xmlns:people的值是xsd文件中的targetNamespace
     2 xmlns:hero 可以写成xmlns:xxx,此时标签前缀也要是 <xxx:hero/>
    -->
    <people:hero name="hlb" age="18"/>

</beans>